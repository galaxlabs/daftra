  {
    "doctype": "Print Format",
    "name": "Daftra Timesheet",
    "print_format_name": "Daftra Timesheet",
    "doc_type": "Time Entry",
    "module": "Daftra Time Tracking",
    "standard": "Yes",
    "print_format_type": "Jinja",
    "html": "\n<h1>Timesheet Invoice</h1>\n<p>Client: {{ doc.client or '' }}</p>\n<table style=\"width:100%;border-collapse:collapse;\"><thead><tr><th style=\"text-align:left;border-bottom:1px solid #111;padding:8px;\">Task</th><th style=\"text-align:right;border-bottom:1px solid #111;padding:8px;\">Hours</th><th style=\"text-align:right;border-bottom:1px solid #111;padding:8px;\">Rate</th><th style=\"text-align:right;border-bottom:1px solid #111;padding:8px;\">Amount</th></tr></thead><tbody><tr><td style=\"padding:8px;border-bottom:1px solid #ddd;\">{{ doc.task }}</td><td style=\"padding:8px;border-bottom:1px solid #ddd;text-align:right;\">{{ doc.duration_hours }}</td><td style=\"padding:8px;border-bottom:1px solid #ddd;text-align:right;\">{{ doc.hourly_rate }}</td><td style=\"padding:8px;border-bottom:1px solid #ddd;text-align:right;\">{{ doc.billable_amount }}</td></tr></tbody></table>\n",
    "disabled": 0
  },
