ing:8px;border-bottom:1px solid #ddd;text-align:right;\">{{ row.rate }}</td><td style=\"padding:8px;border-bottom:1px solid #ddd;text-align:right;\">{{ row.vat_amount or 0 }}</td><td style=\"padding:8px;border-bottom:1px solid #ddd;text-align:right;\">{{ row.amount }}</td></tr>{% endfor %}</tbody>\n  </table>\n  <div style=\"margin-left:auto;margin-top:16px;width:280px;\"><p>Subtotal: {{ doc.subtotal or 0 }}</p><p>VAT: {{ doc.tax_amount or 0 }}</p><h3>Total: {{ doc.total or 0 }}</h3></div>\n  <div style=\"display:flex;justify-content:space-between;margin-top:52px;\"><span>Prepared By __________________</span><span>Received By __________________</span></div>\n</div>\n",
    "disabled": 0
  },
  {
    "doctype": "Print Format",
    "name": "Daftra Receipt 80mm",
    "print_format_name": "Daftra Receipt 80mm",
    "doc_type": "Sales Invoice",
    "module": "Daftra Sales",
    "standard": "Yes",
    "print_format_type": "Jinja",
    "html": "\n<div style=\"font-family:monospace;width:280px;font-size:11px;\">\n  <h2 style=\"text-align:center;margin:0 0 8px;\">{{ frappe.db.get_single_value('Daftra Settings', 'company_name') or 'Daftra' }}</h2>\n  <p style=\"text-align:center;margin:0 0 8px;\">{{ doc.name }}<br>{{ doc.invoice_date or doc.modified }}</p>\n  <hr>{% for row in doc.get('items') or [] %}<p>{{ row.item or row.description }}<br>{{ row.qty }} x {{ row.rate }} <span style=\"float:right;\">{{ row.amount }}</span></p>{% endfor %}<hr>\n  <h3>Total <span style=\"float:right;\">{{ doc.total or 0 }}</span></h3>\n  <p style=\"text-align:center;\">Thank you</p>\n</div>\n",
    "disabled": 0
  },
