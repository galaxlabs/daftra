[
  {
    "doctype": "Print Format",
    "name": "Daftra Default Invoice",
    "print_format_name": "Daftra Default Invoice",
    "doc_type": "Sales Invoice",
    "module": "Daftra Sales",
    "standard": "Yes",
    "print_format_type": "Jinja",
    "html": "\n<div class=\"daftra-print\">\n  <div style=\"display:flex;justify-content:space-between;gap:24px;border-bottom:2px solid #1f2937;padding-bottom:14px;margin-bottom:18px;\">\n    <div>\n      <h1 style=\"margin:0;font-size:24px;\">{{ frappe.db.get_single_value('Daftra Settings', 'company_name') or 'Daftra' }}</h1>\n      <p style=\"margin:6px 0 0;\">VAT: {{ frappe.db.get_single_value('Daftra Settings', 'vat_number') or '' }}</p>\n      <p style=\"margin:2px 0 0;\">CR: {{ frappe.db.get_single_value('Daftra Settings', 'cr_number') or '' }}</p>\n    </div>\n    <div style=\"text-align:right;\">\n      <h2 style=\"margin:0;\">{{ doc.doctype }}</h2>\n      <p style=\"margin:6px 0 0;\">{{ doc.name }}</p>\n      <p style=\"margin:2px 0 0;\">{{ doc.invoice_date or doc.quotation_date or doc.transaction_date or doc.modified }}</p>\n    </div>\n  </div>\n  <div style=\"display:flex;justify-content:space-between;margin-bottom:16px;\">\n    <div><strong>Bill To</strong><br>{{ doc.client or doc.supplier or '' }}</div>\n    <div style=\"text-align:right;\"><strong>Status</strong><br>{{ doc.status or '' }}</div>\n  </div>\n  <table style=\"width:100%;border-collapse:collapse;\">\n    <thead><tr><th style=\"border-bottom:1px solid #111;padding:8px;text-align:left;\">Item</th><th style=\"border-bottom:1px solid #111;padding:8px;text-align:right;\">Qty</th><th style=\"border-bottom:1px solid #111;padding:8px;text-align:right;\">Rate</th><th style=\"border-bottom:1px solid #111;padding:8px;text-align:right;\">VAT</th><th style=\"border-bottom:1px solid #111;padding:8px;text-align:right;\">Amount</th></tr></thead>\n    <tbody>{% for row in doc.get('items') or [] %}<tr><td style=\"padding:8px;border-bottom:1px solid #ddd;\">{{ row.item or row.description }}</td><td style=\"padding:8px;border-bottom:1px solid #ddd;text-align:right;\">{{ row.qty }}</td><td style=\"padding:8px;border-bottom:1px solid #ddd;text-align:right;\">{{ row.rate }}</td><td style=\"padding:8px;border-bottom:1px solid #ddd;text-align:right;\">{{ row.vat_amount or 0 }}</td><td style=\"padding:8px;border-bottom:1px solid #ddd;text-align:right;\">{{ row.amount }}</td></tr>{% endfor %}</tbody>\n  </table>\n  <div style=\"margin-left:auto;margin-top:16px;width:280px;\"><p>Subtotal: {{ doc.subtotal or 0 }}</p><p>VAT: {{ doc.tax_amount or 0 }}</p><h3>Total: {{ doc.total or 0 }}</h3></div>\n  <div style=\"display:flex;justify-content:space-between;margin-top:52px;\"><span>Prepared By __________________</span><span>Received By __________________</span></div>\n</div>\n",
    "disabled": 0
  },
  {
